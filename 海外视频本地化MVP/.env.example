# Knowledge Research Orchestrator（KRO）
KNOWLEDGE_RESEARCH_ROOT=\\DS223\obsidian知识库
KRO_CONFIG_PATH=../config/knowledge-sources.json
# KRO_SCRIPT_PATH=   # 可选；默认 ~/.codex/skills/... 或 Downloads 下的 KRO

# 脚本生成（可选）：优先使用 overseas-loc-mvp/.env 中的 ARK_API_KEY（豆包）
# SCRIPT_LLM_PROVIDER=auto   # auto | doubao | anthropic | rule
# DOUBAO_SCRIPT_ENABLED=1
# 若仍要用 Claude，可填：
# ANTHROPIC_API_KEY=
# OVERSEAS_LOC_MODEL=claude-sonnet-4-6

# SeedDance 2.0（fal.ai）密钥写在同级目录 overseas-loc-mvp/.env
# 也可运行工作区根目录「配置SeedDance.cmd」
# FAL_KEY=

# 质量优先 · 控量量产（建议日产 10 条）
PRODUCTION_PROFILE=quality_daily_10
DAILY_SCRIPT_QUOTA=10

DOUBAO_VIDEO_ANALYSIS_ENABLED=1
VIDEO_ANALYSIS_AUTO=0
VIDEO_ANALYSIS_ON_VIEW=0
DECOMPOSE_BATCH_LIMIT=10

# 素材库容量（运行 pipeline prune 或「整理素材库」时使用）
MATERIAL_MAX_TOTAL=80
DISCOVERY_CANDIDATE_MAX=150
MATERIAL_KEEP_ANALYZED=1

# ── 内网部署（可选）────────────────────────────────────────
# 监听地址：内网服务器填 0.0.0.0，本机开发保持 127.0.0.1
# WORKBENCH_HOST=0.0.0.0
# WORKBENCH_PORT=8788
# 访问令牌（设置后所有 /api 请求需带 X-Workbench-Token 或 ?token=）
# WORKBENCH_API_TOKEN=请改为随机长字符串
# 工作区根目录（默认自动识别为上级目录）
# WORKFLOW_ROOT=D:\vl-workflow
# 定时备份目标（默认 工作区/06_备份库）
# WORKFLOW_BACKUP_DIR=D:\vl-backups

# 抓取/同步后自动删除非当前产品品类（1=开启）
MATERIAL_SCOPE_TRIM=1
# MATERIAL_DEFAULT_PRODUCT=便携恒温杯

# 脚本生成（与拆解共用 ARK_API_KEY）
# OVERSEAS_DB_USERNAME=
# OVERSEAS_DB_PASSWORD=
